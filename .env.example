# =============================================================================
# exitBotauto - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to version control!

# =============================================================================
# SNAPTRADE (Robinhood Integration)
# =============================================================================
SNAPTRADE_CLIENT_ID=your_snaptrade_client_id
SNAPTRADE_CONSUMER_KEY=your_snaptrade_consumer_key
SNAPTRADE_USER_ID=your_snaptrade_user_id
SNAPTRADE_USER_SECRET=your_snaptrade_user_secret

# =============================================================================
# POLYGON.IO (Market Data)
# =============================================================================
POLYGON_API_KEY=your_polygon_api_key
POLYGON_PREMIUM_API_KEY=your_polygon_premium_api_key  # Optional, for higher rate limits

# =============================================================================
# TWITTER/X API (Sentiment Analysis)
# =============================================================================
X_API_KEY=your_x_api_key
X_API_SECRET=your_x_api_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_SECRET=your_x_access_secret
X_BEARER_TOKEN=your_x_bearer_token  # Optional, for v2 API

# =============================================================================
# NEWS APIs (Sentiment & Breaking News)
# =============================================================================
NEWS_API_KEY=your_news_api_key
MARKETAUX_API_KEY=your_marketaux_api_key  # Optional, alternative news source
FINNHUB_API_KEY=your_finnhub_api_key      # Optional, financial news

# =============================================================================
# AI APIs (Decision Making & Analysis)
# =============================================================================
OPENAI_API_KEY=your_openai_api_key        # For GPT-4 meta-reasoning
ANTHROPIC_API_KEY=your_anthropic_api_key  # For Claude analysis
PERPLEXITY_API_KEY=your_perplexity_api_key  # For real-time news

# =============================================================================
# DATABASE (Optional - for logging & history)
# =============================================================================
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_supabase_service_key

# =============================================================================
# BOT CONFIGURATION
# =============================================================================

# Risk Management
MAX_POSITION_SIZE=200           # Max $ per position
MAX_CONCURRENT_POSITIONS=5      # Max number of simultaneous positions
MAX_DAILY_LOSS_PCT=3.0          # Max daily loss % before circuit breaker
MAX_POSITION_LOSS_PCT=1.0       # Stop loss % per position
TAKE_PROFIT_PCT=2.0             # Take profit target %
TRAILING_STOP_PCT=0.5           # Trailing stop distance %

# Capital Management
TOTAL_CAPITAL=10000             # Total account size
DEPLOYED_CAPITAL=1000           # Amount actively deployed
POSITION_SIZE_PCT=2.0           # Position size as % of account

# Trading Hours (ET)
TRADING_START_HOUR=9            # Start trading hour (9 = 9:30am)
TRADING_START_MINUTE=30         # Start trading minute
TRADING_END_HOUR=15             # Stop trading hour (15 = 3:30pm)
TRADING_END_MINUTE=30           # Stop trading minute
CLOSE_ALL_EOD=true              # Close all positions before market close

# Scanner Configuration
SCAN_INTERVAL_SECONDS=300       # Run scanner every 5 minutes
MIN_PRICE=5.0                   # Minimum stock price
MAX_PRICE=500.0                 # Maximum stock price
MIN_VOLUME=1000000              # Minimum average daily volume
VOLUME_SPIKE_MULTIPLIER=2.0     # Volume spike threshold (2x = 200%)
MIN_MOMENTUM_PCT=2.0            # Minimum price momentum %

# Sentiment Thresholds
MIN_ENTRY_SENTIMENT=0.5         # Minimum sentiment score for entry (-1 to 1)
EXIT_SENTIMENT_WARNING=0.3      # Sentiment warning level
EXIT_SENTIMENT_CRITICAL=0.0     # Immediate exit sentiment level

# Dashboard
DASHBOARD_PORT=8000             # FastAPI dashboard port
DASHBOARD_HOST=0.0.0.0          # Dashboard host (0.0.0.0 = all interfaces)

# Logging
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
LOG_TO_FILE=true                # Log to file in logs/
LOG_TO_CONSOLE=true             # Log to console
LOG_TO_DB=false                 # Log to Supabase (requires SUPABASE_* vars)

# Alerts (Optional)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
ENABLE_ALERTS=true              # Enable Telegram alerts

# Paper Trading (for testing)
PAPER_TRADING_MODE=false        # Set to true to simulate trades without real orders

# =============================================================================
# ADVANCED CONFIGURATION (Leave defaults unless you know what you're doing)
# =============================================================================

# API Rate Limits
POLYGON_RATE_LIMIT=5            # Requests per second
TWITTER_RATE_LIMIT=15           # Requests per 15 minutes
NEWS_API_RATE_LIMIT=100         # Requests per day

# Retry Configuration
MAX_ORDER_RETRIES=3             # Max retries for failed orders
ORDER_RETRY_DELAY=30            # Seconds between order retries
API_TIMEOUT_SECONDS=10          # HTTP request timeout

# Cache Configuration
CACHE_MARKET_DATA_SECONDS=5     # Cache Polygon data for 5 seconds
CACHE_SENTIMENT_SECONDS=60      # Cache sentiment data for 1 minute

# Performance
MAX_WORKERS=10                  # Max concurrent async workers
ENABLE_WEBSOCKET=true           # Use WebSocket for real-time data
