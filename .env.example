# =============================================================================
# Velox / exitBotauto - Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in real values.
# Never commit `.env`.

# -----------------------------------------------------------------------------
# API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=

# Twitter / X
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=

# Brokerage / Market Data
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
PAPER_MODE=false
POLYGON_API_KEY=
UW_API_TOKEN=
FRED_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# -----------------------------------------------------------------------------
# Trading Parameters
# -----------------------------------------------------------------------------
TOTAL_CAPITAL=25000
DEPLOYED_CAPITAL=25000
POSITION_SIZE_PCT=2.0
MAX_CONCURRENT_POSITIONS=5
MAX_DAILY_LOSS_PCT=3.0
MAX_POSITION_LOSS_PCT=1.0
TAKE_PROFIT_1_PCT=1.5
TAKE_PROFIT_2_PCT=2.5
TRAILING_STOP_PCT=0.5
STOP_LOSS_PCT=1.0
MAX_HOLD_HOURS=4
EOD_EXIT_TIME=15:30

# -----------------------------------------------------------------------------
# Scanner Parameters
# -----------------------------------------------------------------------------
MIN_PRICE=5.0
MAX_PRICE=500.0
MIN_VOLUME=1000000
VOLUME_SPIKE_MULTIPLIER=2.0
MIN_MOMENTUM_PCT=2.0
SCAN_INTERVAL_SECONDS=300
SCAN_INTERVAL_FAST_SECONDS=60
SCAN_INTERVAL_SLOW_SECONDS=300
SCAN_INTERVAL_EXTENDED_SECONDS=300
SCAN_INTERVAL_OVERNIGHT_SECONDS=600
SCAN_REGIME_HYSTERESIS_WINDOW=3
SCAN_REGIME_MIN_CONFIRMATIONS=2
SCANNER_TECHNICAL_FETCH_DELAY_SECONDS=0.26
SCANNER_SIGNAL_FIRST_SEEN_TTL_SECONDS=3600
FAST_PATH_ENABLED=true
FAST_PATH_MIN_CHANGE_PCT=5.0
FAST_PATH_MIN_VOLUME_SPIKE=2.0
FAST_PATH_SIZE_MULTIPLIER=0.4
FAST_PATH_RSI_MIN=40
FAST_PATH_RSI_MAX=85
FAST_PATH_EVAL_MAX_CYCLES=6
FAST_PATH_EVAL_MAX_AGE_SECONDS=90
SWING_MODE_TRAIL_PCT=4.5
SWING_MODE_SIZE_REDUCTION=0.7
SWING_MODE_DISABLE_FAST_PATH=true
COPY_TRADER_MODE=auto
COPY_TRADER_SIGNAL_WINDOW_SECONDS=900
COPY_TRADER_STREAM_STALE_SECONDS=180
COPY_TRADER_STREAM_RULE_REFRESH_SECONDS=3600
COPY_TRADER_EXIT_TIGHTEN_MULT=0.6
COPY_TRADER_EXIT_MIN_TRAIL_PCT=1.5
COPY_TRADER_STRONG_EXIT_MIN_SIGNALS=2
COPY_TRADER_AUTO_EXIT_STRONG=false

# -----------------------------------------------------------------------------
# Sentiment Thresholds
# -----------------------------------------------------------------------------
MIN_ENTRY_SENTIMENT=0.3
EXIT_SENTIMENT_WARNING=0.3
EXIT_SENTIMENT_CRITICAL=0.0

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8421
# Required for dashboard/API access after auth hardening.
DASHBOARD_TOKEN=change_me

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Risk Management (Advanced)
# -----------------------------------------------------------------------------
ATR_PERIOD=14
ATR_STOP_MULTIPLIER=1.5
ATR_TRAIL_MULTIPLIER=2.0
WEEKLY_MAX_LOSS_PCT=5.0
EXTENDED_HOURS_SIZE_MULT=0.5
MAX_PRICE_CHASE_PCT=0.5
CASH_ACCOUNT=true
MAX_SECTOR_PCT=40.0

# -----------------------------------------------------------------------------
# Consensus Engine
# -----------------------------------------------------------------------------
CONSENSUS_ENABLED=true
CONSENSUS_MIN_CONFIDENCE=70
CONSENSUS_CACHE_SECONDS=300
CONSENSUS_MAX_CALLS_PER_HOUR=60
OPENAI_MODEL=gpt-5.2
CLAUDE_MODEL=claude-sonnet-4-5-20250929
XAI_MODEL=grok-4-fast-reasoning
PERPLEXITY_MODEL=sonar-pro
JURY_RETRO_ENABLED=true
JURY_RETRO_LOOKBACK_TRADES=40
JURY_RETRO_MIN_MATCHES=3

# -----------------------------------------------------------------------------
# Options Trading
# -----------------------------------------------------------------------------
OPTIONS_ENABLED=false
OPTIONS_ALLOCATION_PCT=50
OPTIONS_MONITOR_INTERVAL_SECONDS=30
OPTIONS_CONTRACT_DTE_MIN=7
OPTIONS_CONTRACT_DTE_MAX=21
OPTIONS_TARGET_DTE=12
OPTIONS_TARGET_DELTA=0.40
OPTIONS_MIN_OPEN_INTEREST=10
OPTIONS_PREMIUM_TRAIL_PCT=35
OPTIONS_PREMIUM_TIGHT_TRAIL_PCT=20
OPTIONS_PREMIUM_STOP_LOSS_PCT=50
OPTIONS_PREMIUM_PROFIT_TARGET_PCT=100
OPTIONS_PREMIUM_TRIPLE_TARGET_MULT=3.0
OPTIONS_MIN_DAYS_TO_EXPIRY=2
OPTIONS_MAX_PORTFOLIO_PCT=10
OPTIONS_EXIT_BID_AWARE_LIMIT=true
OPTIONS_EXIT_BID_DISCOUNT_PCT=0.25
OPTIONS_EXIT_MID_DISCOUNT_PCT=2.0
OPTIONS_EXIT_MARKET_FALLBACK=true

# -----------------------------------------------------------------------------
# Payload Capture (paper trading diagnostics)
# -----------------------------------------------------------------------------
# When true, raw Alpaca REST/WebSocket payloads are written to data/alpaca_capture/
CAPTURE_ALPACA_PAYLOADS=false

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=
